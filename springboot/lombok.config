# lombok.config — place this at the project root (same level as pom.xml)
# Stops Lombok searching parent directories for more config files
config.stopBubbling = true

# Tell Lombok which Jackson version to target for @Jacksonized / @Builder deserialization.
# We use Jackson 2 (the version bundled with Spring Boot 3.x).
# Without this, newer Lombok versions print a warning asking you to choose.
lombok.jackson.version = 2

# Use @FieldNameConstants style that matches Jackson property naming
lombok.fieldNameConstants.innerTypeName = Fields

# Suppress all Lombok-generated toString/equals/hashCode on @Data classes
# that have fields marked transient — prevents accidental serialisation
lombok.addSuppressWarnings = true
